  function pluginPerfMetricsMount() {
    if (!isInstalled('perfMetrics')) { pluginPerfMetricsUnmount(); return; }
    if (perfEl) return;
    var pos = getPluginSetting('perfMetrics','pos') || 'top-right';
    var posCSS = pos === 'top-left'      ? 'top:14px;left:14px'
