  }

  function pluginAnimBGDraw() {
    if (!animBGEl) return;
    var preset = getPluginSetting('animBG','preset') || 'particles';
    var intensity = (parseInt(getPluginSetting('animBG','intensity')) || 60) / 100;
    var c = animBGEl, ctx = c.getContext('2d');
    var menu = document.getElementById('km-menu');
    c.width  = (menu ? menu.offsetWidth  : 0) || 500;
    c.height = (menu ? menu.offsetHeight : 0) || 560;
    var W = c.width, H = c.height, t = 0;

    // Shared particle pool
    var pts = [];
    if (preset === 'particles' || preset === 'space') {
      var count = Math.round(40 * intensity);
      for (var i=0;i<count;i++) pts.push({x:Math.random()*W,y:Math.random()*H,vx:(Math.random()-.5)*0.4,vy:(Math.random()-.5)*0.4,r:Math.random()*1.5+0.5,hue:Math.random()*360});
    }
    if (preset === 'matrix') {
      var cols = Math.floor(W/10), drops = [];
      for (var i=0;i<cols;i++) drops[i] = Math.random()*H/14|0;
    }
    var glitchTimer = 0;

    function tick() {
      animBGRaf = requestAnimationFrame(tick);
      t++;
      // Update canvas size if menu was resized
      var _m = document.getElementById('km-menu');
      if (_m && (_m.offsetWidth !== W || _m.offsetHeight !== H)) {
        W = c.width  = _m.offsetWidth  || 500;
        H = c.height = _m.offsetHeight || 560;
      }
      ctx.clearRect(0,0,W,H);

      if (preset === 'particles') {
        pts.forEach(function(p) {
          p.x+=p.vx; p.y+=p.vy;
          if(p.x<0||p.x>W) p.vx*=-1;
          if(p.y<0||p.y>H) p.vy*=-1;
          ctx.beginPath(); ctx.arc(p.x,p.y,p.r,0,Math.PI*2);
          ctx.fillStyle='hsla('+p.hue+',80%,70%,0.7)'; ctx.fill();
        });
        // Connect close particles
        for(var i=0;i<pts.length;i++) for(var j=i+1;j<pts.length;j++){
          var dx=pts[i].x-pts[j].x, dy=pts[i].y-pts[j].y, dist=Math.sqrt(dx*dx+dy*dy);
          if(dist<60){ctx.beginPath();ctx.moveTo(pts[i].x,pts[i].y);ctx.lineTo(pts[j].x,pts[j].y);ctx.strokeStyle='rgba(255,255,255,'+(1-dist/60)*0.15+')';ctx.lineWidth=0.5;ctx.stroke();}
        }
      } else if (preset === 'matrix') {
        ctx.fillStyle='rgba(0,10,0,0.05)'; ctx.fillRect(0,0,W,H);
        ctx.fillStyle='#0f0'; ctx.font='10px monospace';
        for(var i=0;i<drops.length;i++){
          var ch=String.fromCharCode(0x30A0+Math.random()*96|0);
          ctx.fillStyle='rgba(0,'+(150+Math.random()*105|0)+',0,'+(0.5+Math.random()*0.5)+')';
          ctx.fillText(ch,i*10,drops[i]*14);
          if(drops[i]*14>H && Math.random()>0.975) drops[i]=0;
          drops[i]++;
        }
      } else if (preset === 'aurora') {
        for(var y=0;y<H;y+=4){
          var alpha=(Math.sin(y*0.02+t*0.008)*0.5+0.5)*0.08*intensity;
          var hue=180+Math.sin(y*0.01+t*0.005)*60;
          ctx.fillStyle='hsla('+hue+',80%,60%,'+alpha+')';
          ctx.fillRect(0,y,W,4);
        }
        // Vertical wave bands
        for(var x=0;x<W;x+=2){
          var a=(Math.sin(x*0.015+t*0.01)*0.5+0.5)*0.04*intensity;
          ctx.fillStyle='rgba(100,255,200,'+a+')';
          ctx.fillRect(x,0,2,H);
        }
      } else if (preset === 'neon-grid') {
        var accent = document.getElementById('km-menu') ? getComputedStyle(document.getElementById('km-menu')).borderTopColor : '#3b82f6';
        var gridSize = 40;
        var offsetX = (t * 0.5) % gridSize;
        var offsetY = (t * 0.3) % gridSize;
        ctx.strokeStyle = 'rgba(100,200,255,0.08)'; ctx.lineWidth = 0.5;
        for(var x=-gridSize;x<W+gridSize;x+=gridSize){ctx.beginPath();ctx.moveTo(x+offsetX,0);ctx.lineTo(x+offsetX,H);ctx.stroke();}
        for(var y=-gridSize;y<H+gridSize;y+=gridSize){ctx.beginPath();ctx.moveTo(0,y+offsetY);ctx.lineTo(W,y+offsetY);ctx.stroke();}
        // Glowing node at intersections
        for(var x=0;x<W;x+=gridSize) for(var y=0;y<H;y+=gridSize){
          var blink=Math.sin(t*0.05+(x+y)*0.05)*0.5+0.5;
          if(blink>0.85){ctx.beginPath();ctx.arc(x+offsetX%gridSize,y+offsetY%gridSize,1.5,0,Math.PI*2);ctx.fillStyle='rgba(100,200,255,0.5)';ctx.fill();}
        }
      } else if (preset === 'fire') {
        var fireData = new Uint8ClampedArray(W*H*4);
        for(var x=0;x<W;x++) fireData[((H-1)*W+x)*4+3]=255, fireData[((H-1)*W+x)*4]=(Math.random()*200+55)|0;
        for(var y=H-2;y>=0;y--) for(var x=0;x<W;x++){
          var i=((y+1)*W+((x-1+W)%W))*4, j=((y+2)*W+(x))*4, k=((y+1)*W+((x+1)%W))*4;
          var v=((fireData[i]+fireData[j]+fireData[k])*0.9/3)|0;
          var idx=(y*W+x)*4; fireData[idx]=v; fireData[idx+3]=v>10?255:0;
          fireData[idx+1]=Math.max(0,v-100); fireData[idx+2]=0;
        }
        var img=ctx.createImageData(W,H); img.data.set(fireData); ctx.putImageData(img,0,0);
      } else if (preset === 'space') {
        ctx.fillStyle='rgba(0,0,0,0.2)'; ctx.fillRect(0,0,W,H);
        pts.forEach(function(p){
          p.x+=p.vx*0.2; p.y+=p.vy*0.2;
          if(p.x<0)p.x=W; if(p.x>W)p.x=0; if(p.y<0)p.y=H; if(p.y>H)p.y=0;
          var twinkle=Math.sin(t*0.05+p.hue)*0.4+0.6;
          ctx.beginPath();ctx.arc(p.x,p.y,p.r*0.7,0,Math.PI*2);
          ctx.fillStyle='rgba(255,255,255,'+twinkle*0.6+')';ctx.fill();
        });
        // Nebula blobs
        for(var i=0;i<3;i++){
          var nx=W*(0.2+i*0.3),ny=H*0.5+Math.sin(t*0.003+i)*H*0.1;
          var grad=ctx.createRadialGradient(nx,ny,0,nx,ny,120);
          grad.addColorStop(0,'hsla('+(200+i*50)+',60%,50%,0.03)');
          grad.addColorStop(1,'transparent');
          ctx.fillStyle=grad; ctx.fillRect(0,0,W,H);
        }
      } else if (preset === 'waveform') {
        ctx.strokeStyle='rgba(96,165,250,0.4)'; ctx.lineWidth=1.5;
        for(var band=0;band<3;band++){
          ctx.beginPath();
          var hue=[210,270,180][band];
          ctx.strokeStyle='hsla('+hue+',70%,65%,'+(0.15+band*0.07)+')';
          for(var x=0;x<W;x++){
            var y=H/2+Math.sin(x*0.02+t*0.04+band*2)*30*intensity
              +Math.sin(x*0.05+t*0.02+band)*15*intensity;
            x===0?ctx.moveTo(x,y):ctx.lineTo(x,y);
          }
          ctx.stroke();
        }
      } else if (preset === 'glitch') {
        glitchTimer++;
        if(glitchTimer%8===0){
          var sliceH=Math.random()*20+4|0, sy=Math.random()*H|0;
          var shift=(Math.random()*30-15)|0;
          ctx.drawImage(c,0,sy,W,sliceH,shift,sy,W,sliceH);
        }
        if(Math.random()<0.1*intensity){
          ctx.fillStyle='rgba(255,0,0,'+(Math.random()*0.04)+')'; ctx.fillRect(0,0,W,H);
          ctx.fillStyle='rgba(0,255,200,'+(Math.random()*0.03)+')'; ctx.fillRect(0,0,W,H);
        }
        if(Math.random()<0.05){
          var lx=Math.random()*W|0, ly=Math.random()*H|0, lw=Math.random()*W/2+20|0;
          ctx.fillStyle='rgba(255,255,255,0.06)'; ctx.fillRect(lx,ly,lw,1+Math.random()*2|0);
        }
      }
    }
    tick();
  }

